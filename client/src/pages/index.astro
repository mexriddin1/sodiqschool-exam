---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import StageDetail from '../components/StageDetail.astro';
import LockedSection from '../components/LockedSection.astro';
import { isUnlocked } from '../lib/section-access';
import { fetchMyResult } from '../lib/session';
import {
  pickSubject, resolveOverrides, applyBloomFallback, resolveVerdict,
  BLOOM_FALLBACK_MATH, SKILL_RADAR_FALLBACK_MATH, REASONING_FALLBACK_MATH,
} from '../lib/client-data';
import { computeReport, BAND_COLORS, pctColor, scoreBand } from '@sodiq/compute/compute';
import { verdictFor } from '@sodiq/compute/composite';

const me = await fetchMyResult(Astro);
if (!me) return Astro.redirect('/login');
const student = pickSubject(me, 'MATH');
const overrides = resolveOverrides(me);
const ov = overrides.math;
import { buildPrograms } from '../lib/programs.js';
import { tierUnits, strandDonut, bloomLadder, topicDots, skillRadarChart, reasoningConstellation, heroInstrument, scoreScale, growthDumbbell, skillRoad } from '../lib/svg.js';

const r = computeReport(student);
import { adjustedSubtitle } from '../lib/adjusted-label';
import { buildBloomBars } from '../lib/bloom-fill';
const m = r.meta;
const programs = buildPrograms(r);
// Section access gates — roadmap unlocks only after admin grants access
// (parent visits school). Overview metrics stay visible.
const gate = {
  roadmap: isUnlocked(me.unlockedSections, 'roadmap'),
};
// AI narrative injected into §Diagnostika / §Tahlil / §Rivojlanish.
// Falls back to the deterministic long-form story when generation hasn't run.
import { aiParagraphs, hasAiText } from '../lib/ai-md';
const aiSubj = me.aiNarrative?.math ?? null;
// roadmap stops (essentials only) + the journey's end-goal label
const roadStops = programs.map((p) => ({ n: p.num - 10, range: p.range, label: p.road.label, gain: p.road.gain, note: p.road.note, color: p.priority.color }));
const roadFinishVal = r.growthForecast[r.growthForecast.length - 1].v;
// --- COHORT STANDING (resolved from snapshot.cohort or manualContent.cohort) -
// Values come from recomputeCohortRanks() at publish time, or from an admin
// override on manualContent.cohort. Male-only ranking renders only when sex
// is known and maleTotal/maleRank are provided.
const studentSex = overrides.studentSex;
// Cohort standing: subject-level manual override (ov.cohort) wins; otherwise
// we use snapshot.subjectCohort.MATH (per-subject rank), falling back to the
// composite snapshot.cohort for results published before this feature landed.
const snapshotCohort = ((me.calculatedSnapshot as any)?.subjectCohort?.MATH ?? me.calculatedSnapshot?.cohort ?? {}) as {
  rank?: number | null; total?: number | null; percentile?: number | null;
  male?: { rank: number; total: number; percentile: number } | null;
  female?: { rank: number; total: number; percentile: number } | null;
};
const sexBlock = studentSex === 'male' ? snapshotCohort.male : studentSex === 'female' ? snapshotCohort.female : null;
const cohort = {
  ...ov.cohort,
  rank: ov.cohort.rank ?? snapshotCohort.rank ?? null,
  total: ov.cohort.total ?? snapshotCohort.total ?? null,
  percentile: ov.cohort.percentile ?? snapshotCohort.percentile ?? null,
  maleRank: ov.cohort.maleRank ?? (studentSex === 'male' ? sexBlock?.rank ?? null : null),
  maleTotal: ov.cohort.maleTotal ?? (studentSex === 'male' ? sexBlock?.total ?? null : null),
  femaleRank: (ov.cohort as any).femaleRank ?? (studentSex === 'female' ? sexBlock?.rank ?? null : null),
  femaleTotal: (ov.cohort as any).femaleTotal ?? (studentSex === 'female' ? sexBlock?.total ?? null : null),
};
const hasCohort = cohort.rank != null && cohort.total != null && cohort.percentile != null;

// ---- derived narrative bits (all computed, never hand-set) -----------------
const weakestTopic = r.weakestTopic;
const strongTopics = r.strongTopics;
// Bloom levels — real % from r.byBloom where measured; per-key admin override
// (or shipped default) for any lowConfidence group.
const bloomLevels = applyBloomFallback(ov.bloomFallback, BLOOM_FALLBACK_MATH);
// Bloom bars keep the qualitative label so the client can render "A'lo" /
// "Mustahkam" etc. instead of a raw percent. See lib/bloom-fill.ts.
const bloomData = buildBloomBars(r);
// Skill radar / reasoning fallback: stretch shipped defaults toward the
// student's overall percent so a 96% child never sees a 70% skill. Preserves
// relative strengths (radar shape) but shifts absolute values up.
function scaleRadar(items, refPercent) {
  // Perfect score → every axis pinned to 100. Otherwise blend fallback with
  // the student's actual percent, capping at max(98, refPercent) so a
  // near-perfect score isn't artificially clipped.
  if (refPercent >= 100) return items.map((s) => ({ ...s, value: 100 }));
  const lo = Math.max(60, refPercent - 15);
  const hi = Math.min(100, Math.max(98, refPercent));
  return items.map((s) => {
    const blended = Math.round(0.4 * s.value + 0.6 * refPercent);
    return { ...s, value: Math.max(lo, Math.min(hi, blended)) };
  });
}
const skillRadar = ov.skillRadar?.length
  ? ov.skillRadar
  : r.bySkill.length > 0
    ? r.bySkill.sort((a, b) => b.n - a.n).slice(0, 7).map((s) => ({ name: s.name, value: s.percent }))
    : scaleRadar(SKILL_RADAR_FALLBACK_MATH, r.percent);
const reasoningTypes = ov.reasoningTypes?.length
  ? ov.reasoningTypes
  : r.byReasoning.length > 0
    ? r.byReasoning.map((g) => {
        const fb = REASONING_FALLBACK_MATH.find((f) => f.name === g.name);
        return { name: g.name, value: g.percent, gloss: fb?.gloss ?? '' };
      })
    : scaleRadar(REASONING_FALLBACK_MATH, r.percent);
// §12 growth matrix — every 0-100 measure with a transparent diminishing-returns
// projection of where the roadmap lifts it (weaker areas gain more, capped ~95).
// Values mirror the same numbers shown in §6/§8/§9/§10 so the report stays consistent.
const proj = (v) => Math.max(v, Math.min(96, Math.round(v + (96 - v) * 0.5)));
const growthGroups = [
  { title: 'Umumiy', rows: [{ name: 'Umumiy ball', from: r.percent, to: roadFinishVal }] },
  { title: "Matematik bo'limlar", rows: r.byStrand.map((g) => ({ name: g.name, from: g.percent, to: proj(g.percent) })) },
  { title: 'Bilim darajalari (Bloom)', rows: bloomData.map((b) => ({ name: b.key, from: b.percent, to: proj(b.percent) })) },
  { title: "Asosiy ko'nikmalar", rows: skillRadar.map((s) => ({ name: s.name, from: s.value, to: proj(s.value) })) },
  { title: 'Fikrlash turlari', rows: reasoningTypes.map((t) => ({ name: t.name, from: t.value, to: proj(t.value) })) },
];
// §1 story helpers — strongest/weakest across the displayed dimensions
const topStrand = [...r.byStrand].sort((a, b) => b.percent - a.percent)[0];
const topReason = [...reasoningTypes].sort((a, b) => b.value - a.value)[0];
const lowSkill = [...skillRadar].sort((a, b) => a.value - b.value)[0];
const lowBloom = [...bloomData].sort((a, b) => a.percent - b.percent)[0];
const topPct = hasCohort && cohort.percentile != null ? 100 - cohort.percentile : null;
// Glossary entries — admin override wins; else shipped defaults.
const SKILL_HELP_DEFAULT = [
  { t: 'Protsedural ravonlik', d: `amallarni ravon, tez va to'g'ri bajarish — yuqori bo'lsa hisob-kitob avtomatlashgan.` },
  { t: 'Konseptual tushunish', d: `qoidaning ma'nosini anglash (faqat yodlash emas) — chuqur o'rganishga asos.` },
  { t: 'Muammo yechish', d: `notanish masalaga strategiya tuzib yechish — mustaqillik belgisi.` },
  { t: 'Mantiqiy xulosa', d: `ma'lumotdan asosli xulosa chiqarish — qiyin masalalarni uddalaydi.` },
  { t: 'Fazoviy fikrlash', d: `shakl, fazo va o'lchovni tasavvur qilish — geometriya uchun muhim.` },
  { t: 'Modellashtirish', d: `real vaziyatni matematik shaklga keltirish — amaliy masalalarda asqotadi.` },
  { t: 'Hisoblash aniqligi', d: `amallarni xatosiz bajarish — past bo'lsa e'tiborsizlik xatolari ko'payadi.` },
];
const BLOOM_HELP_DEFAULT = [
  { t: 'Eslab qolish', d: `faktlar va qoidalarni yodda saqlash (eng oddiy daraja).` },
  { t: 'Tushunish', d: `ma'noni anglash, o'z so'zi bilan tushuntirish.` },
  { t: "Qo'llash", d: `o'rganilgan qoidani yangi misolda ishlatish.` },
  { t: 'Tahlil', d: `masalani qismlarga ajratib, bog'liqliklarni ko'rish.` },
  { t: 'Baholash', d: `tanlovni asoslab, mulohaza bilan baho berish.` },
  { t: 'Yaratish', d: `yangi yechim yoki g'oya ishlab chiqish (eng yuqori, chuqur fikrlash darajasi).` },
];
const REASON_HELP_DEFAULT = [
  { t: 'Deduktiv', d: `umumiy qoidadan aniq natijaga (qoida → misol) — ishonchli, izchil fikrlash.` },
  { t: 'Induktiv', d: `misollardan umumiy qoidaga (qonuniyat topish) — kashfiyotchi fikrlash.` },
  { t: 'Analitik', d: `murakkabni qismlarga ajratib tahlil qilish.` },
  { t: 'Fazoviy', d: `shakl va fazoni tasavvur qilib fikrlash — geometriya va modellarda.` },
];
const skillHelp = ov.glossary.skillHelp?.length ? ov.glossary.skillHelp : SKILL_HELP_DEFAULT;
const bloomHelp = ov.glossary.bloomHelp?.length ? ov.glossary.bloomHelp : BLOOM_HELP_DEFAULT;
const reasonHelp = ov.glossary.reasonHelp?.length ? ov.glossary.reasonHelp : REASON_HELP_DEFAULT;
// Simpler cover: subject-scoped title, no marketing subtitle.
const coverTitle = ov.narrative.coverTitle ?? `${m.subject} imtihoni diagnostikasi`;
const coverSubtitle = ov.narrative.coverSubtitle ?? '';
const adminStory = ov.narrative.story && ov.narrative.story.length > 0 ? ov.narrative.story : null;
// Verdict — auto from potential, or admin override. Uses the same
// verdictFor() as the admin snapshot so label/sub/color are identical.
const verdict = resolveVerdict(verdictFor(r.potential), overrides.summary.verdictOverride);
// Strength label — admin override wins; otherwise derive from the computed report.
const strengthLabel = ov.strength
  ? ov.strength
  : r.hardTierPct >= 75
    ? 'murakkab, mantiqiy masalalar'
    : strongTopics[0]
      ? strongTopics[0].toLowerCase()
      : 'asosiy mavzular';
const technicalPctOfLost = r.lostTotal ? Math.round((r.technicalLost / r.lostTotal) * 100) : 0;
const potentialBand = scoreBand(r.potential); // band for the POTENTIAL (not today's score)
const adjustedBand = scoreBand(r.adjusted);   // band for the adjusted score (tuzatilgan)


// ------ dynamic Mundarija ------
// Each section is listed with a `show` predicate derived from the actual
// data (questions labels, admin overrides, etc.). Empty sections are
// filtered out and remaining ones are renumbered sequentially in the TOC.
// Section visibility is driven by the ACTUAL question labels — not by the
// admin fallbacks. If the test doesn't carry a given dimension (skill, bloom,
// reasoning, topic, strand, difficulty…), we drop that section entirely so
// the TOC only lists what the test measures.
const hasStrand    = r.byStrand.length > 0;
const hasTopic     = r.topics.length > 0;
const hasSkillTag  = r.bySkill.length > 0;
const hasBloomTag  = r.byBloom.length > 0;
const hasReasonTag = r.byReasoning.length > 0;
const hasDifficulty = r.tiers['Oson'].n + r.tiers["O'rta"].n + r.tiers['Qiyin'].n > 0;
const rawSections = [
  { id: 'sec1',  t: 'Bir qarashda — eng muhimi',    show: true },
  { id: 'sec2',  t: 'Umumiy natija va xatolar',    show: true },
  { id: 'sec3',  t: 'Har bir savol (batafsil)',    show: r.questions.length > 0 },
  { id: 'sec4',  t: 'Xato turini aniqlash usuli',  show: r.errorRoster.length > 0 },
  { id: 'sec5',  t: 'Bilim chuqurligi',            show: hasDifficulty },
  { id: 'sec6',  t: "Matematik bo'limlar",         show: hasStrand },
  { id: 'sec7',  t: "Mavzular bo'yicha",           show: hasTopic },
  { id: 'sec8',  t: "Ko'nikmalar profili",         show: hasSkillTag },
  { id: 'sec9',  t: 'Fikrlash darajalari',         show: hasBloomTag },
  { id: 'sec10', t: 'Fikrlash turlari',            show: hasReasonTag },
  { id: 'sec11', t: "Rivojlanish yo'li (yo'l xaritasi)", show: programs.length > 0 },
  { id: 'sec12', t: "Ko'nikmalar o'sishi",         show: growthGroups.length > 0 },
];
const sections = rawSections.filter((s) => s.show).map((s, i) => ({ ...s, n: i + 1 }));
const showSection = (id) => sections.some((s) => s.id === id);
// Section id → zero-padded number that matches the (filtered) TOC.
// Falls back to '' if the section is hidden, so callers can guard on it.
const nn = (id) => {
  const found = sections.find((s) => s.id === id);
  return found ? String(found.n).padStart(2, '0') : '';
};

---

<Layout title={`Sodiq School — ${m.subject} diagnostika`} meta={m}>
  {/* ============================== COVER ============================== */}
  <header class="cover">
    <div class="wrap">
      <div class="brandline">
        <img class="brand-logo" src="/logo-white.png" width="1920" height="700" alt={m.school} />
        <span class="brand-div"></span>
        <div>
          <div class="slogan">{m.slogan}</div>
        </div>
      </div>
      <h1>{coverTitle}</h1>
      {coverSubtitle && <div class="subtitle">{coverSubtitle}</div>}
      <div class="meta">
        <div><b>Nomzod:</b> {m.candidate}</div>
        <div><b>Sinf:</b> {m.gradeLabel}</div>
        <div><b>Imtihon:</b> {m.subject} · <span class="num">{m.totalQuestions}</span> savol · <span class="num">{m.totalMarks}</span> ball</div>
      </div>

      <div class="hero-instrument hero-instrument--stacked">
        <div>
          <div class="hero-readout">
            <span class="big">{r.percent}</span><span class="slash">/100</span>
            <span class="ci">taxminan {r.ci.low}–{r.ci.high}</span>
          </div>
          <div set:html={heroInstrument(r.percent, r.ci)} />
          {/* Under-score row: Tuzatilgan · Salohiyat · To'g'ri · Persentil · Umumiy reyting · (jinsga qarab) Yigitlar/Qizlar orasida. */}
          <div class="hero-mini">
            <div class="metric"><div class="metric-value sm num">~{r.adjusted}</div><div class="metric-label">Tuzatilgan</div></div>
            <div class="metric"><div class="metric-value sm num">{r.potential}</div><div class="metric-label">Salohiyat</div></div>
            <div class="metric"><div class="metric-value sm num">{r.correctCount}/{r.totalQuestions}</div><div class="metric-label">To'g'ri</div></div>
            <div class="metric"><div class="metric-value sm num">{cohort.percentile != null ? <>{cohort.percentile}<span class="u">-foiz</span></> : '—'}</div><div class="metric-label">Persentil</div></div>
            <div class="metric"><div class="metric-value sm num">{cohort.rank != null ? <>{cohort.rank}<span class="u">/{cohort.total}</span></> : '—'}</div><div class="metric-label">Umumiy reyting</div></div>
            {studentSex === 'male' && (
              <div class="metric"><div class="metric-value sm num">{cohort.maleRank != null ? <>{cohort.maleRank}<span class="u">/{cohort.maleTotal}</span></> : '—'}</div><div class="metric-label">Yigitlar orasida</div></div>
            )}
            {studentSex === 'female' && (
              <div class="metric"><div class="metric-value sm num">{cohort.femaleRank != null ? <>{cohort.femaleRank}<span class="u">/{cohort.femaleTotal}</span></> : '—'}</div><div class="metric-label">Qizlar orasida</div></div>
            )}
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="wrap">
    {/* ============================== TOC ============================== */}
    <section class="section" id="toc">
      <header class="sec-head">
        <div class="eyebrow">Mundarija</div>
        <h2>Bo'limlar</h2>
        <p class="lead">Eng muhimi — boshida (1-bo'lim). Qolgan bo'limlar batafsil tahlil.</p>
      </header>
      <div class="toc"><ol>
        {sections.map((s) => (
          <li><span class="nn">{s.n}</span><span class="t"><a href={`#${s.id}`}>{s.t}</a></span><span class="dots"></span><span class="pg">✓</span></li>
        ))}
      </ol></div>
    </section>

    {/* ===================== PART I ===================== */}
    <div class="part"><span class="pn">I</span><span class="pt">Diagnostika</span><span class="pr"></span><span class="pe">§1–5</span></div>

    {/* 1 · SNAPSHOT */}
    <section class="section" id="sec1">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec1')}</div>
        <h2>Bir qarashda</h2>
        <p class="lead">Butun hisobotning sodda, hikoya tarzidagi xulosasi.</p>
      </header>
      <div class="story">
        {adminStory ? adminStory.map((p) => <p set:html={p} />) : hasAiText(aiSubj?.diagnostika) ? (
          aiParagraphs(aiSubj.diagnostika).map((h) => (<p set:html={h} />))
        ) : <>
        <p>
          Farzandingiz matematika imtihonida 100 balldan <b>{r.percent}</b> ball oldi —
          natija <b>{r.band.label.toLowerCase()}</b> ({r.band.tavsif?.toLowerCase()}).
          {hasCohort && (
            <>{' '}Bu {cohort.total} nafar nomzod orasida <b>yuqori ~{topPct}%</b> natija ({cohort.rank}-o'rin){studentSex === 'male' && cohort.maleRank != null && <>, yigitlar orasida esa <b>{cohort.maleRank}-o'rin</b></>}.</>
          )}
        </p>
        <p>
          Eng kuchli tomoni — <b>{strengthLabel}</b>. {topStrand.name} bo'limida <b>{topStrand.percent}%</b>,
          {' '}{topReason.name.toLowerCase()} fikrlashda <b>{topReason.value}%</b>: bola murakkab, ko'p bosqichli masalalarni mantiq bilan yechadi
          va yuqori darajadagi (tahlil, baholash) savollardan cho'chimaydi. Bu — kuchli akademik poydevor belgisi.
        </p>
        <p>
          Eng muhim jihat — yo'qotilgan ballarning <b>{technicalPctOfLost}% i e'tiborsizlik (texnik) xatosi</b>, bilmaslik emas.
          Bola materialni biladi, ammo shoshqaloqlik yoki javobni tekshirmaslik tufayli ball boy beradi. Shuning uchun haqiqiy darajasi ko'ringan {r.percent} balldan yuqori:
          umumiy salohiyat bahosi <b>{r.potential}</b>, e'tiborsizlik xatolari tuzatilsa esa ball <b>~{r.adjusted}</b> ga yetadi.
          Bu — quvonarli xabar, chunki diqqat va tekshirish odatini mashq qilish bilim bo'shlig'ini to'ldirishdan ancha tez kechadi.
        </p>
        <p>
          O'sish uchun asosiy yo'nalish — <b>{weakestTopic ? weakestTopic.name.toLowerCase() : 'tor mavzu'}</b>{weakestTopic && <> ({weakestTopic.percent}%)</>}, hozircha eng bo'sh mavzu.
          Shuningdek, {lowSkill.name.toLowerCase()} ({lowSkill.value}%) va qonuniyat topish (induktiv fikrlash) mustahkamlanishi,
          ijodiy ({lowBloom.key.toLowerCase()}) topshiriqlar esa rivojlanishi foydali. Bular kamchilik emas — aniq va erishsa bo'ladigan o'sish nuqtalari.
        </p>
        <p>
          Quyidagi uch bosqichli, 12 oylik yo'l xaritasi aynan shu yo'nalishlarni qadam-baqadam mustahkamlaydi.
          Reja izchil bajarilsa, umumiy ball {r.percent} dan <b>~{roadFinishVal}</b> ga ko'tariladi va barcha ko'rsatkichlar — kasrdan tortib fikrlash turlarigacha — o'sadi.
          Umuman, farzandingizning matematik salohiyati <b>{potentialBand.label.toLowerCase()}</b>.
        </p>
        </>}
      </div>
    </section>

    {/* 2 · OVERALL + ERROR */}
    <section class="section" id="sec2">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec2')}</div>
        <h2>Umumiy natijalar</h2>
      </header>
      <div class="statcards">
        <div class="statcard">
          <div class="sl">Ball</div>
          <span class="toifa-badge" style={`background:${r.band.color}`}>{r.band.label}</span>
          <div class="sv" style={`color:${r.band.color}`}>{r.percent}<span class="unit">/100</span></div>
          <div class="rule" style={`background:${r.band.color}`}></div>
          <div class="sd">Bugungi imtihon natijasi</div>
        </div>
        <div class="statcard">
          <div class="sl">Taxmin oralig'i</div>
          <div class="sv">{r.ci.low}–{r.ci.high}</div>
          <div class="rule" style="background:#6B7385"></div>
          <div class="sd">Bitta test taxminiy — haqiqiy daraja shu oraliqda</div>
        </div>
        <div class="statcard">
          <div class="sl">Tuzatilgan baho</div>
          <div class="sv" style={`color:${adjustedBand.color}`}>~{r.adjusted}</div>
          <div class="rule" style={`background:${adjustedBand.color}`}></div>
          <div class="sd">{adjustedSubtitle(r)}</div>
        </div>
      </div>
      <div class="scale-connect" set:html={scoreScale(r.percent, r.adjusted, r.ci, { joriy: r.band.color, taxmin: '#6B7385', tuzatilgan: adjustedBand.color })} />
    </section>

    {/* 3 · PER-QUESTION */}
    {showSection('sec3') && (
    <section class="section" id="sec3">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec3')}</div>
        <h2>Har bir savol</h2>
      </header>
      <div class="table-wrap"><table>
        <thead><tr><th>#</th><th class="col-icon"></th><th>Kichik Mavzu</th><th>Ko'nikma</th><th>Bloom</th><th>Qiy.</th><th class="col-num">Ball</th></tr></thead>
        <tbody>
          {r.questions.map((q) => {
            const ok = q.result === "To'g'ri";
            return (
              <tr class={ok ? '' : 'miss'}>
                <td class="q">{q.id}</td>
                <td class={`col-icon ${ok ? 'res-ok' : 'res-no'}`}>{ok ? '✓' : '✗'}</td>
                <td>{q.subTopic || q.topic}</td>
                <td>{q.skill}</td>
                <td><span class="tag">{q.bloom}</span></td>
                <td>{q.difficulty}</td>
                <td class="col-num">{q.earned}</td>
              </tr>
            );
          })}
        </tbody>
      </table></div>
    </section>
    )}

    {/* 4 · ERROR-TYPE METHODOLOGY */}
    {showSection('sec4') && (
    <section class="section" id="sec4">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec4')}</div>
        <h2>Texnik xato va haqiqiy bilim bo'shlig'ini qanday ajratamiz</h2>
        <p class="lead">"Bilmadi"mi yoki "biladi-yu e'tibor bermadi"mi — buni qanday aniqlaganimiz.</p>
      </header>
      {r.errorRoster.length === 0 ? (
        <div class="note pos">
          <b>Xatolar yo‘q.</b> Farzandingiz barcha savollarni to‘g‘ri yechdi —
          tahlil qilinadigan xato mavjud emas.
        </div>
      ) : (
        <>
          <div class="note"><b>Usuli sodda.</b> Yechilmagan savol uchun tekshiramiz: bola xuddi shu ko'nikmali, lekin <b>qiyinroq</b> savolni yechganmi? Yechgan bo'lsa — bu <b>texnik (e'tiborsizlik)</b> xatosi; yechmagan bo'lsa — haqiqiy <b>bilim bo'shlig'i</b>.</div>
          <div class="table-wrap"><table>
            <thead><tr><th>Savol</th><th>Xulosa</th><th>Izoh</th></tr></thead>
            <tbody>
              {r.errorRoster.map((e) => (
                <tr>
                  <td class="q">{e.id}</td>
                  <td><span class={`status ${e.isTechnical ? 'info' : 'neg'}`}>{e.isTechnical ? 'Texnik xato' : "Bilim bo'shlig'i"}</span></td>
                  <td class="muted">{e.techNotes?.length ? e.techNotes.join(' · ') : e.evidence}</td>
                </tr>
              ))}
            </tbody>
          </table></div>
        </>
      )}
    </section>
    )}

    {/* 5 · KNOWLEDGE DEPTH */}
    {showSection('sec5') && (
    <section class="section" id="sec5">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec5')}</div>
        <h2>Bilim chuqurligi</h2>
      </header>
      <div class="tier-units" set:html={tierUnits(r.tiers)} />
      </section>
    )}

    {/* ===================== PART II ===================== */}
    <div class="part"><span class="pn">II</span><span class="pt">Tahlil</span><span class="pr"></span><span class="pe">§6–9</span></div>

    {/* 6 · SUBJECT */}
    {showSection('sec6') && (
    <section class="section" id="sec6">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec6')}</div>
        <h2>Matematik bo'limlar bo'yicha o'zlashtirish</h2>
      </header>
      <div class="strand-cards">
        {r.strandDetails.map((s) => (
          <div class="strand-card">
            <h4 class="strand-name">{s.name}</h4>
            <div set:html={strandDonut(s.percent, s.correct, s.n, pctColor(s.percent))} />
            <div class="strand-qs"><b>{s.n} ta savol:</b> {s.ids.join(', ')}</div>
          </div>
        ))}
      </div>
    </section>
    )}

    {/* 7 · TOPICS */}
    {showSection('sec7') && (
    <section class="section" id="sec7">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec7')}</div>
        <h2>Mavzular bo'yicha</h2>
      </header>
      <div class="topic-chart" set:html={topicDots(r.topics)} />
    </section>
    )}

    {/* 8 · SKILLS + 9 · BLOOM */}
    {(showSection('sec8') || showSection('sec9')) && (
    <div class="section-pair">
      {showSection('sec8') && (
      <section class="section" id="sec8">
        <header class="sec-head">
          <div class="eyebrow">{nn('sec8')}</div>
          <div class="h2row"><h2>Ko'nikmalar profili</h2><button class="info-btn" type="button" aria-expanded="false" aria-controls="help-skill" aria-label="Atamalar izohi" title="Atamalar izohi">i</button></div>
          <p class="lead">Yetti asosiy matematik ko'nikma bo'yicha kuch-quvvat xaritasi.</p>
        </header>
        <div class="term-help" id="help-skill" hidden>
          <div class="th-label">Atamalar — ma'no va ahamiyati</div>
          <dl>{skillHelp.map((x) => (<div><dt>{x.t}</dt><dd>{x.d}</dd></div>))}</dl>
        </div>
        <div class="skill-radar" set:html={skillRadarChart(skillRadar)} />
        <p class="caption" style="text-align:center">Shakl qanchalik tekis bo'lsa, ko'nikmalar shunchalik muvozanatli; bir tomonga cho'zilgan bo'lsa — o'sha ko'nikma ustun.</p>
      </section>
      )}

      {showSection('sec9') && (
      <section class="section" id="sec9">
        <header class="sec-head">
          <div class="eyebrow">{nn('sec9')}</div>
          <div class="h2row"><h2>Fikrlash darajalari</h2><button class="info-btn" type="button" aria-expanded="false" aria-controls="help-bloom" aria-label="Atamalar izohi" title="Atamalar izohi">i</button></div>
          <p class="lead">Bola fikrlashi qaysi <b>darajada</b> ishlaydi (Bloom — pastdan yuqoriga murakkablashadi).</p>
        </header>
        <div class="term-help" id="help-bloom" hidden>
          <div class="th-label">Bloom darajalari — ma'no va ahamiyati</div>
          <dl>{bloomHelp.map((x) => (<div><dt>{x.t}</dt><dd>{x.d}</dd></div>))}</dl>
        </div>
        <div set:html={bloomLadder(bloomData)} />
      </section>
      )}
    </div>
    )}

    {/* 10 · REASONING TYPES */}
    {showSection('sec10') && (
    <section class="section" id="sec10">
      <header class="sec-head">
        <div class="eyebrow">{nn('sec10')}</div>
        <div class="h2row"><h2>Fikrlash turlari</h2><button class="info-btn" type="button" aria-expanded="false" aria-controls="help-reason" aria-label="Atamalar izohi" title="Atamalar izohi">i</button></div>
      </header>
      <div class="term-help" id="help-reason" hidden>
        <div class="th-label">Fikrlash turlari — ma'no va ahamiyati</div>
        <dl>{reasonHelp.map((x) => (<div><dt>{x.t}</dt><dd>{x.d}</dd></div>))}</dl>
      </div>
      <div class="reasoning-constel" set:html={reasoningConstellation(reasoningTypes)} />
      <div class="constel-legend">
        {reasoningTypes.map((d) => (
          <span><b>{d.name}</b> — {d.gloss}</span>
        ))}
      </div>
    </section>
    )}

    {/* ===================== PART III ===================== */}
    <div class="part"><span class="pn">III</span><span class="pt">Rivojlanish yo'li</span><span class="pr"></span><span class="pe">§11–12</span></div>

    {/* 11 · THE ROADMAP — a road with three stops. Yopiq bo'lsa haqiqiy
        content blur qilinadi va ustidan qulf overlay chiqadi. */}
    {showSection('sec11') && (
    <LockedSection eyebrow="11–12" title="Rivojlanish yo'li"
      hint="3, 6 va 12 oylik dastur, o'sish prognozi va bosqichma-bosqich reja."
      locked={!gate.roadmap}>
      <section class="section" id="sec11">
        <header class="sec-head">
          <div class="eyebrow">{nn('sec11')}</div>
          <h2>Rivojlanish yo'li</h2>
          <p class="lead"><b>Hozir</b>dan <b>maqsad</b> sari uch bosqichli yo'l — har biri oldingisining davomi. Sahifani pastga suring: velosiped yo'l bo'ylab yuradi.</p>
        </header>
        <div class="skill-road" set:html={skillRoad(roadStops, { finish: 'Maqsad', finishSub: `umumiy ball ~${roadFinishVal}` })} />
        <p class="road-hint">Bosqich tafsilotini ko'rish uchun yo'ldagi <b>raqamni</b> yoki quyidagi tugmani bosing.</p>
        <div class="stage-tabs" role="tablist" aria-label="Bosqichlar">
          {programs.map((p, i) => (
            <button class="stage-tab" type="button" role="tab" data-stage={i} aria-selected={i === 0 ? 'true' : 'false'}>
              <span class="st-n">{i + 1}</span><span class="st-t"><b>{i + 1}-bosqich</b> · {p.range}</span>
            </button>
          ))}
        </div>
        <div class="stage-details">
          {programs.map((p, i) => <StageDetail program={p} idx={i + 1} />)}
        </div>
      </section>
    </LockedSection>
    )}

    {/* 12 · SKILL GROWTH (payoff of the roadmap) */}
    {showSection('sec12') && (
    <LockedSection eyebrow="12" title="O'sish imkoniyati"
      hint="Har o'lchanadigan ko'rsatkichning hozirgi va prognozli darajasi."
      locked={!gate.roadmap}>
      <section class="section" id="sec12">
        <header class="sec-head">
          <div class="eyebrow">{nn('sec12')}</div>
          <h2>O'sish imkoniyati</h2>
          <p class="lead">Har bir o'lchanadigan ko'rsatkich (100 balldan) — <b>hozir</b> va reja bajarilgach <b>kutilayotgan daraja</b>. Eng zaif joylar eng ko'p o'sadi.</p>
        </header>
        <div class="growth-dumbbell" set:html={growthDumbbell(growthGroups)} />
        <p class="caption center">Bu nimani ko'rsatadi: bo'sh nuqta — hozirgi daraja; rangli bo'laklar — 3, 6 va 12 oylik bosqichlardagi o'sish; to'q (navy) nuqta — reja so'ngida kutilayotgan daraja. Proyeksiya shaffof qoida bilan hisoblanadi (zaif joy ko'proq o'sadi, yuqori chegara ~95) — kafolat emas, yo'nalish.</p>
      </section>
    </LockedSection>
    )}

  </div>

  <script>
    // cyclist rides the road as the section scrolls through the viewport
    const road = document.querySelector('.skill-road');
    const path = document.getElementById('roadPath');
    const bike = document.getElementById('roadBike');
    if (road && path && bike && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const L = path.getTotalLength();
      let ticking = false;
      const place = () => {
        const rc = road.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const prog = Math.max(0, Math.min(1, (vh * 0.55 - rc.top) / rc.height));
        const pt = path.getPointAtLength(prog * L);
        bike.setAttribute('transform', `translate(${pt.x} ${pt.y})`);
        ticking = false;
      };
      const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(place); } };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      place();
    }

    // stage detail: tabs + clickable road stops reveal one panel at a time
    const tabs = [...document.querySelectorAll('.stage-tab')];
    const panels = [...document.querySelectorAll('.stage-detail')];
    const hits = [...document.querySelectorAll('.road-stop-hit')];
    if (tabs.length && panels.length) {
      const select = (i) => {
        tabs.forEach((t, k) => t.setAttribute('aria-selected', k === i ? 'true' : 'false'));
        panels.forEach((pn, k) => { pn.hidden = k !== i; });
        hits.forEach((s, k) => s.classList.toggle('is-active', k === i));
      };
      tabs.forEach((t, i) => t.addEventListener('click', () => select(i)));
      hits.forEach((s, i) => s.addEventListener('click', () => { select(i); panels[i].scrollIntoView({ behavior: 'smooth', block: 'start' }); }));
      select(0);
    }

    // info buttons: toggle a term-definitions panel (each prints in the PDF)
    document.querySelectorAll('.info-btn').forEach((btn) => {
      const panel = document.getElementById(btn.getAttribute('aria-controls'));
      if (!panel) return;
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        panel.hidden = open;
      });
    });
  </script>
</Layout>
