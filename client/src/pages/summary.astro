---
export const prerender = false;
// Cross-subject SUMMARY dashboard — combines the three diagnostic reports
// (Matematika, Ingliz tili, Tanqidiy fikrlash) into one at-a-glance page.
// New structure: composite hero -> 3-subject triptych -> cross-cutting insights.
import Layout from '../layouts/Layout.astro';
import AdmissionCelebration from '../components/AdmissionCelebration.astro';
import LockedSection from '../components/LockedSection.astro';
import { isUnlocked } from '../lib/section-access';
import { fetchMyResult } from '../lib/session';
import { isReportReady, pickSubject, resolveOverrides, resolveVerdict } from '../lib/client-data';
import { computeReport, BAND_COLORS, scoreBand } from '@sodiq/compute/compute';
import { extractWeights, DEFAULT_SUBJECT_WEIGHTS, verdictFor } from '@sodiq/compute/composite';

const me = await fetchMyResult(Astro);
if (!me) return Astro.redirect('/login');
// Chala natija (masalan faqat matematika topshirilgan) — hisobot
// uchala fansiz chizilmaydi, shuning uchun 500 o'rniga tushuntirish.
if (!isReportReady(me)) return Astro.redirect('/not-ready');
const mathData = pickSubject(me, 'MATH');
const englishData = pickSubject(me, 'ENGLISH');
const ctData = pickSubject(me, 'CRITICAL_THINKING');
const overrides = resolveOverrides(me);
import { strandDonut, scoreScale } from '../lib/svg.js';

// Per-subject CFG — strength/growthLabel/rank come from manualContent per
// subject; never hardcoded narrative.
const CFG = [
  { name: 'Matematika', eyebrow: 'Fan 1', data: mathData, ov: overrides.math, href: '/' },
  { name: 'Ingliz tili', eyebrow: 'Fan 2', data: englishData, ov: overrides.english, href: '/english' },
  { name: 'Tanqidiy fikrlash', eyebrow: 'Fan 3', data: ctData, ov: overrides.criticalThinking, href: '/critical-thinking' },
];
const subjects = CFG.map((c) => {
  const r = computeReport(c.data);
  return {
    name: c.name, eyebrow: c.eyebrow, href: c.href,
    strength: c.ov.strength ?? '—',
    growthLabel: c.ov.growthLabel ?? '—',
    rank: c.ov.cohort.rank,
    total: c.ov.cohort.total,
    percent: r.percent, potential: r.potential, adjusted: r.adjusted, band: r.band,
    techPct: r.lostTotal ? Math.round((r.technicalLost / r.lostTotal) * 100) : 0,
  };
});
const avg = (a) => Math.round(a.reduce((x, y) => x + y, 0) / a.length);
// Read composite weights from the exam config so the "how is umumiy ball
// calculated" panel matches the number we display.
const { weights: subjectWeights, source: weightsSource } = extractWeights(me.exam.gradingConfiguration, me.student.grade);
const WKEYS = ['MATH', 'ENGLISH', 'CRITICAL_THINKING'];
const WEIGHT_BY_INDEX = [subjectWeights.MATH, subjectWeights.ENGLISH, subjectWeights.CRITICAL_THINKING];
const weightedAvg = (vals) => {
  const sumW = WEIGHT_BY_INDEX.reduce((s, w) => s + w, 0);
  if (sumW === 0) return 0;
  return Math.round(vals.reduce((s, v, i) => s + v * WEIGHT_BY_INDEX[i], 0) / sumW);
};
const composite = weightedAvg(subjects.map((s) => s.percent));
const compPotential = weightedAvg(subjects.map((s) => s.potential));
const compAdjusted = weightedAvg(subjects.map((s) => s.adjusted));
// Display-friendly weight percents with 1 decimal so equal thirds show as
// 33.3% instead of 33% (which sums to 99% and looks broken).
const fmtPct = (w) => {
  const v = w * 100;
  return Number.isInteger(v) ? String(v) : v.toFixed(1);
};
const weightPct = {
  math: fmtPct(subjectWeights.MATH),
  english: fmtPct(subjectWeights.ENGLISH),
  ct: fmtPct(subjectWeights.CRITICAL_THINKING),
};
const compBand = scoreBand(composite);
const adjustedBand = scoreBand(compAdjusted);
const avgTechPct = avg(subjects.map((s) => s.techPct));
const topSubj = [...subjects].sort((a, b) => b.percent - a.percent)[0];
const lowSubj = [...subjects].sort((a, b) => a.percent - b.percent)[0];
// Verdict — read from the frozen snapshot, which is the single source of
// truth: it is the only place the subject-gate demotion exists, because
// /api/result/me deliberately never ships admissionThresholds to the client.
// Recomputing it here (as this page did until 2026-07-15) silently disagreed
// with what admin published. Fall back to the band only if a published result
// somehow has no snapshot; that path cannot apply the gate.
const snapshotVerdict = (me.calculatedSnapshot as any)?.composite?.verdict as
  | { label: string; sub: string; color: string }
  | undefined;
const verdict = resolveVerdict(
  snapshotVerdict ?? verdictFor(compPotential),
  overrides.summary.verdictOverride,
);

// Summary-level overrides (overallRank/overallPct/crossStrength/gradeLabel).
const sumOv = overrides.summary;
const overallRank = sumOv.overallRank;
const overallTotal = sumOv.overallTotal;
const overallPct = sumOv.overallPct;
const hasOverall = overallRank != null && overallTotal != null && overallPct != null;
// Sex-split standing from snapshot.cohort.male/female (auto-computed).
const sexRank = sumOv.sexRank;
const sexTotal = sumOv.sexTotal;
const hasSexRank = sexRank != null && sexTotal != null;
const sexLabel = me.student.sex === 'MALE' ? "Yigitlar orasida" : me.student.sex === 'FEMALE' ? "Qizlar orasida" : null;
const crossStrength = sumOv.crossStrength;

const compCi = { low: Math.max(0, composite - 3), high: Math.min(100, composite + 3) };
// Section-level access gates. Overview blocks (score, band, per-fan cards)
// are always visible; narrative/risks/roadmap unlock only after the parent
// visits the school (admin toggles Result.unlockedSections).
const gate = {
  narrative: isUnlocked(me.unlockedSections, 'narrative'),
};
const m = {
  ...mathData.meta,
  subject: 'Umumiy xulosa',
  gradeLabel: sumOv.gradeLabel ?? `${mathData.meta.grade}-sinfga nomzod · 3 fan`,
};
const chip = (c) => `background:${c}1A;color:${c};border-color:${c}55`;
const growthList = subjects.filter((s) => s.growthLabel !== '—').map((s) => `${s.name.toLowerCase()} - ${s.growthLabel}`).join('; ');
// If admin manualContent didn't set strength/growthLabel we derive them from
// bySkill (the radar/spider axes). Ties are included — if multiple skills share
// the top (or bottom) percent they are all listed. 100% total = special labels.
function autoStrength(rep, subjectPercent) {
  if (subjectPercent >= 100) return 'barchasi kuchli';
  const skills = rep.bySkill ?? [];
  if (!skills.length) return null;
  const maxPct = Math.max(...skills.map((s) => s.percent));
  return skills.filter((s) => s.percent === maxPct).map((s) => s.name.toLowerCase()).join(', ');
}
function autoWeak(rep, subjectPercent) {
  if (subjectPercent >= 100) return "zaif tomoni yo'q";
  const skills = rep.bySkill ?? [];
  if (!skills.length) return null;
  const minPct = Math.min(...skills.map((s) => s.percent));
  return skills.filter((s) => s.percent === minPct).map((s) => s.name.toLowerCase()).join(', ');
}
// Backfill '—' fields on the subjects list computed above with auto derivations.
subjects.forEach((s, i) => {
  const data = [mathData, englishData, ctData][i];
  const rep = computeReport(data);
  if (s.strength === '—' || !s.strength) s.strength = autoStrength(rep, s.percent) ?? '—';
  if (s.growthLabel === '—' || !s.growthLabel) s.growthLabel = autoWeak(rep, s.percent) ?? '—';
});
---
<Layout title={`Sodiq School — Umumiy diagnostik xulosa`} meta={m}>
  <AdmissionCelebration verdictLabel={verdict.label} studentName={m.candidate} />
  {/* ============================== COVER ============================== */}
  <header class="cover">
    <div class="wrap">
      <div class="brandline">
        <img class="brand-logo" src="/logo-white.png" width="1920" height="700" alt={m.school} />
        <span class="brand-div"></span>
        <div>
          <div class="slogan">{m.slogan}</div>
        </div>
      </div>
      <h1>Umumiy diagnostik xulosa</h1>
      <div class="subtitle">Uch kirish imtihoni — matematika, ingliz tili va tanqidiy fikrlash — bir sahifada</div>
      <div class="meta">
        <div><b>Nomzod:</b> {m.candidate}</div>
        <div><b>Sinf:</b> {m.gradeLabel}</div>
        <div><b>Imtihonlar:</b> <span class="num">3</span> fan · har biri <span class="num">100</span> ball</div>
      </div>

      <div class="hero-instrument">
        <div>
          <div class="hero-readout">
            <span class="big">{composite}</span><span class="slash">/100</span>
            <span class="ci">Umumiy natija</span>
          </div>
          <div class="hero-mini">
            {subjects.map((s) => (
              <div class="metric"><div class="metric-value sm num">{s.percent}</div><div class="metric-label">{s.name}</div></div>
            ))}
          </div>
          <div class="hero-rank">
            {hasOverall && (
              <>
                <div class="metric"><div class="metric-value sm num">{overallRank}<span class="u">/{overallTotal}</span></div><div class="metric-label">Umumiy reyting</div></div>
                <div class="metric"><div class="metric-value sm num">{overallPct}<span class="u">-foiz</span></div><div class="metric-label">Persentil</div></div>
              </>
            )}
            {hasSexRank && sexLabel && (
              <div class="metric"><div class="metric-value sm num">{sexRank}<span class="u">/{sexTotal}</span></div><div class="metric-label">{sexLabel}</div></div>
            )}
            <div class="metric"><div class="metric-value sm num">{compPotential}</div><div class="metric-label">Salohiyat o'rt.</div></div>
          </div>
        </div>
        <div>
          <div class="hero-verdict" style={`background:${verdict.color}`}>
            <div class="hv-seal">✓</div>
            <div class="hv-label">{verdict.label}</div>
            <small>{verdict.sub}</small>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="wrap">
    {/* ---- short narrative (gated: narrative). Yopiq bo'lsa real hikoya blur. */}
    <LockedSection eyebrow="01" title="Bir qarashda"
      hint="Uch fan bo'yicha qisqacha diagnostika hikoyasi va e'tibor beriladigan yo'nalishlar."
      locked={!gate.narrative}>
      <section class="section" id="sec1">
        <header class="sec-head">
          <div class="eyebrow">01</div>
          <h2>Bir qarashda</h2>
        </header>
        <div class="story">
          <p>
            Farzandingiz uch kirish imtihonida umumiy <b>{composite}/100</b> ball oldi —
            <b>{compBand.label.toLowerCase()}</b> ({compBand.tavsif?.toLowerCase()}).
            Eng yuqori natija — <b>{topSubj.name.toLowerCase()}</b> ({topSubj.percent}).
          </p>
          {crossStrength && (
            <p>
              Cross-fan eng kuchli tomoni — <b>{crossStrength}</b>.{' '}
              Yo'qotilgan ballarning <b>~{avgTechPct}% i e'tiborsizlik (texnik) xatosi</b>,
              bilmaslik emas. Tuzatilgan umumiy ball — ~{compAdjusted}.
            </p>
          )}
          {growthList && (
            <p>
              O'sish yo'nalishlari: <b>{growthList}</b>.{' '}
              Umumiy salohiyat <b>{compPotential}</b>; tavsiya — <b>{verdict.label.toLowerCase()}</b>.
            </p>
          )}
        </div>
      </section>
    </LockedSection>

    {/* ---- overall band scale (toifa) ---- */}
    <section class="section" id="sec2">
      <header class="sec-head">
        <div class="eyebrow">02</div>
        <h2>Umumiy daraja</h2>
        <p class="lead">Umumiy ball qaysi <b>toifada</b> — va e'tiborsizliksiz qayergacha yetadi.</p>
      </header>
      <div class="statcards">
        <div class="statcard">
          <div class="sl">Umumiy natija</div>
          <span class="toifa-badge" style={`background:${compBand.color}`}>{compBand.label}</span>
          <div class="sv" style={`color:${compBand.color}`}>{composite}<span class="unit">/100</span></div>
          <div class="rule" style={`background:${compBand.color}`}></div>
          <div class="sd">Uch fan bo'yicha umumiy</div>
        </div>
        <div class="statcard">
          <div class="sl">Taxmin oralig'i</div>
          <div class="sv">{compCi.low}–{compCi.high}</div>
          <div class="rule" style="background:#6B7385"></div>
          <div class="sd">Haqiqiy daraja shu oraliqda</div>
        </div>
        <div class="statcard">
          <div class="sl">Tuzatilgan baho</div>
          <div class="sv" style={`color:${adjustedBand.color}`}>~{compAdjusted}</div>
          <div class="rule" style={`background:${adjustedBand.color}`}></div>
          <div class="sd">{compAdjusted > composite ? "E'tiborsizlik xatolari va yarim javoblar tuzatilsa erishiladigan daraja" : "Xato yo'q — hozirgi daraja to'liq"}</div>
        </div>
      </div>
      <div class="scale-connect" set:html={scoreScale(composite, compAdjusted, compCi, { joriy: compBand.color, taxmin: '#6B7385', tuzatilgan: adjustedBand.color })} />

      {/* ---- Umumiy ball qanday hisoblanadi (weights table) ---- */}
      <div class="weight-panel">
        <div class="weight-head">
          <h3>Umumiy ball qanday hisoblandi</h3>
          <div class="weight-sub">
            {weightsSource === 'exam'
              ? `${mathData.meta.grade}-sinf imtihoni uchun rasman belgilangan fanlar og'irligi`
              : `Imtihonda maxsus og'irlik ko'rsatilmagan — uchala fan teng ulush bilan hisoblandi`}
          </div>
        </div>
        <table class="weight-table">
          <thead>
            <tr>
              <th>Fan</th>
              <th class="num">Fan bali</th>
              <th class="num">Og'irlik</th>
              <th class="num">Ulushi</th>
            </tr>
          </thead>
          <tbody>
            {subjects.map((s, i) => {
              const w = WEIGHT_BY_INDEX[i];
              // Keep one decimal so the ×33.3% row sums correctly. When the
              // weight is a whole percent (e.g. 40%), we drop the decimal.
              const wPct = fmtPct(w);
              const contribRaw = s.percent * w;
              const contribStr = (Math.round(contribRaw * 10) / 10).toFixed(1);
              return (
                <tr>
                  <td>{s.name}</td>
                  <td class="num">{s.percent}/100</td>
                  <td class="num">×{wPct}%</td>
                  <td class="num">= {contribStr}</td>
                </tr>
              );
            })}
            <tr class="total-row">
              <td colspan="3">Umumiy ball</td>
              <td class="num"><b>{composite}/100</b></td>
            </tr>
          </tbody>
        </table>
        <p class="weight-note">
          <b>Formula:</b> Umumiy = Matematika × {weightPct.math}% + Ingliz tili × {weightPct.english}% + Tanqidiy fikrlash × {weightPct.ct}%.
          Sinf va imtihonga qarab og'irliklar farq qilishi mumkin — bu ma'lumot imtihon konfiguratsiyasidan olinadi.
        </p>
      </div>
    </section>

    <style>
      .weight-panel { margin-top: 24px; border: 1px solid #E5E7EB; border-radius: 12px; padding: 16px 18px; background: #FAFBFC; }
      .weight-head h3 { margin: 0; font-size: 15px; font-weight: 600; color: #06113C; }
      .weight-sub { font-size: 12px; color: #6B7280; margin-top: 2px; }
      .weight-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 13px; }
      .weight-table th { text-align: left; font-weight: 500; color: #6B7280; text-transform: uppercase; font-size: 10px; letter-spacing: 0.05em; padding: 6px 4px; border-bottom: 1px solid #E5E7EB; }
      .weight-table td { padding: 8px 4px; border-bottom: 1px solid #F3F4F6; }
      .weight-table th.num, .weight-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
      .weight-table tr.total-row td { border-top: 1px solid #06113C; border-bottom: none; padding-top: 10px; font-weight: 500; color: #06113C; }
      .weight-note { margin-top: 10px; font-size: 12px; color: #4B5563; line-height: 1.5; }
    </style>

    {/* ---- three subjects triptych ---- */}
    <section class="section" id="sec3">
      <header class="sec-head">
        <div class="eyebrow">03</div>
        <h2>Uch fan bo'yicha</h2>
        <p class="lead">Har bir fan — ball, reyting, salohiyat va asosiy yo'nalishlar. To'liq tahlil uchun fanni oching.</p>
      </header>
      <div class="subj-trip">
        {subjects.map((s) => (
          <a class="subj-card" href={s.href} style={`--bc:${s.band.color}`}>
            <div class="subj-head">
              <span class="subj-eyebrow">{s.eyebrow}</span>
              <span class="band-chip" style={chip(s.band.color)}>{s.band.label}</span>
            </div>
            <h3 class="subj-name">{s.name}</h3>
            <div class="subj-donut" set:html={strandDonut(s.percent, s.percent, 100, s.band.color)} />
            <div class="subj-rows">
              {s.rank != null && s.total != null && (
                <div class="subj-row"><span class="k">Reyting</span><span class="v num">{s.rank}<span class="u">/{s.total}</span></span></div>
              )}
              <div class="subj-row"><span class="k">Salohiyat</span><span class="v num">{s.potential}</span></div>
              <div class="subj-row top"><span class="k">Kuchli</span><span class="v">{s.strength}</span></div>
              <div class="subj-row weak"><span class="k">Zaif</span><span class="v">{s.growthLabel}</span></div>
            </div>
            <span class="subj-link">To'liq hisobot →</span>
          </a>
        ))}
      </div>
    </section>

  </div>
</Layout>
