{
  "name": "@sodiq/compute",
  "version": "0.1.0",
  "description": "Sodiq School diagnostic computation engine — shared between backend, admin, and client.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compute": {
      "types": "./dist/compute.d.ts",
      "import": "./dist/compute.js"
    },
    "./composite": {
      "types": "./dist/composite.d.ts",
      "import": "./dist/composite.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./roadmap-v2": {
      "types": "./dist/roadmap-v2.d.ts",
      "import": "./dist/roadmap-v2.js"
    },
    "./weak-areas": {
      "types": "./dist/weak-areas.d.ts",
      "import": "./dist/weak-areas.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"import('node:fs').then(fs=>{fs.mkdirSync('dist/data',{recursive:true});for(const f of fs.readdirSync('src/data'))fs.copyFileSync('src/data/'+f,'dist/data/'+f)})\"",
    "watch": "tsc -p tsconfig.json -w",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "files": [
    "dist"
  ]
}
