{
  "name": "@sodiq/compute",
  "version": "0.1.0",
  "description": "Sodiq School diagnostic computation engine — shared between backend, admin, and client.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compute": {
      "types": "./dist/compute.d.ts",
      "import": "./dist/compute.js"
    },
    "./composite": {
      "types": "./dist/composite.d.ts",
      "import": "./dist/composite.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json -w",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "files": [
    "dist"
  ]
}
