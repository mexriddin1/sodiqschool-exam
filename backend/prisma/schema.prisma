// Sodiq School exam result schema.
// Per-question data lives on SubjectResult.questions (JSON) — the structure
// is the source of truth for the diagnostic engine and modelling it
// relationally would explode for no benefit.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EDITOR
}

enum ExamStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ResultStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubjectKey {
  MATH
  ENGLISH
  CRITICAL_THINKING
}

enum StudentSex {
  MALE
  FEMALE
}

// New test-taking flow (natijalar.sodiqschool.uz). These enums support the
// live student test experience — separate from the legacy TestTemplate which
// only carries question STRUCTURE for admin-authored results.
enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  FILL_GAP
  MATCHING
  REORDERING
}

enum TestLanguage {
  UZ
  RU
  EN
}

enum LeadStatus {
  FORM_ONLY
  STARTED
  COMPLETED
  PUBLISHED
}

model AdminUser {
  id           String    @id @default(uuid())
  fullName     String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AuditLog[]
}

model Student {
  id                 String      @id @default(uuid())
  // Kept for backwards compat with older admin flows and the report meta
  // (`meta.candidate`). New records set it to `${firstName} ${lastName}`.
  fullName           String
  firstName          String?
  lastName           String?
  // Externally-issued student UID (e.g. from a school registry). Uniqueness
  // is enforced only when a value is set — nullable rows never collide.
  uid                String?     @unique
  // Language the student sits the exam in: "UZ" / "RU" / other short codes.
  examLanguage       String?
  studentNumber      String?     @unique
  phone              String?
  sex                StudentSex?
  birthDate          DateTime?
  grade              Int
  groupName          String?
  metadata           Json?
  // Parent-facing credentials (2026-07-03). One login per student instead
  // of per Result — so a student with several exams reuses the same code
  // and password. Format: `<LastInit><FirstInit><UID>`. Legacy Result.
  // publicCode / accessPassword remain for old rows but are no longer
  // consulted by the login endpoint.
  loginCode          String?     @unique
  accessPassword     String? // plain, shown to admin
  accessPasswordHash String? // bcrypt, used for auth
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  results Result[]
  leads   Lead[]

  @@index([grade])
}

// A pickable subject in the admin — the source of truth for the "Fanlar"
// admin section. `key` is a free-form string (uppercase snake by convention),
// so admins can add subjects beyond the 3-fan default (PHYSICS, CHEMISTRY,
// BIOLOGY, HISTORY, ...). The old SubjectResult.subject column stays typed
// to the SubjectKey enum for legacy report rendering; new subjects added
// here only appear in the admin picker until a follow-up migration widens
// SubjectResult too.
model Subject {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

model Exam {
  id                   String       @id @default(uuid())
  title                String
  description          String?
  examDate             DateTime
  academicYear         String?
  status               ExamStatus   @default(DRAFT)
  // `grade` kept for legacy rows created before multi-grade landed. New rows
  // set it to the first entry of `grades` so old code paths keep working.
  grade                Int
  // Multi-grade support: an exam targets one or more grades (e.g. [5,6,7,8]).
  grades               Int[]        @default([])
  // Subjects tested by this exam. SubjectKey[] so the client can pull the
  // matching template per (examId, grade, subject).
  subjectKeys          SubjectKey[] @default([])
  admissionThresholds  Json // { "5": { math, ct, en }, ... }
  gradingConfiguration Json // band labels & cutoffs (optional overrides)
  cohortSize           Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  results   Result[]
  templates TestTemplate[]
  tests     Test[]

  @@index([grade, status])
}

model Result {
  id                 String       @id @default(uuid())
  studentId          String
  examId             String
  publicCode         String       @unique
  accessPasswordHash String
  // Plain password stored for admin display. Hash remains the source of truth
  // for public-site authentication.
  accessPassword     String       @default("")
  status             ResultStatus @default(DRAFT)
  manualContent      Json // narratives, overrides, cohort overrides
  calculatedSnapshot Json? // frozen at publish: { math, english, ct, composite }
  // AI-generated per-student narrative for §I Diagnostika, §II Tahlil,
  // §III Rivojlanish yo'li + summary §4/§5. Shape: {
  //   math:   { diagnostika, tahlil, growth },
  //   english,ct: same,
  //   summary: { crossCutting, finalRecommendation }
  // }
  aiNarrative        Json?
  // Token accounting for the DeepSeek runs that produced aiNarrative. Shape:
  // { model, promptTokens, completionTokens, totalTokens, costUsd, generatedAt,
  //   runs: [{ section, promptTokens, completionTokens, ms, ts }] }
  aiUsage            Json?
  // Sections of the parent-facing report that are currently unlocked.
  // Empty [] = only the "overview" hero is visible; parents unlock deeper
  // sections when they visit the school (admin toggles here). Known keys:
  //   "narrative" — Bir qarashda + per-fan diagnostikasi
  //   "roadmap"   — 3/6/12 oylik Rivojlanish yo'li
  //   "risks_notes" — Xatarlar, ota-ona/komissiya xulosalari
  unlockedSections   String[]     @default([])
  publishedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  student  Student         @relation(fields: [studentId], references: [id], onDelete: Restrict)
  exam     Exam            @relation(fields: [examId], references: [id], onDelete: Restrict)
  subjects SubjectResult[]
  // Uchala fan urinishi ham shu natijaga bog'lanadi (1:1 emas).
  attempts TestAttempt[]

  @@index([examId, status])
  @@index([studentId])
}

model SubjectResult {
  id             String     @id @default(uuid())
  resultId       String
  subject        SubjectKey
  totalQuestions Int
  totalMarks     Int
  questions      Json // array of Question objects (see @sodiq/compute types)
  realData       Json? // { percentile, cohortAverage, avgTimeSec }
  manualNotes    Json? // { strength, growthLabel }
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  result Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, subject])
}

// Static test template: the question STRUCTURE (id, marks, difficulty, strand,
// topic, ...) for a given (subject, grade). Per-result outcomes (result,
// earned, errorType, evidence) live on SubjectResult.questions — admin
// imports the template and overlays outcomes per student.
model TestTemplate {
  id        String     @id @default(uuid())
  subject   SubjectKey
  grade     Int
  name      String
  questions Json
  // Optional link to the owning exam. When set, this template is scoped to
  // that exam only; nullable so the shipped seed set (grade 5-11, generic)
  // and legacy rows continue to work as an examId=null "library".
  examId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  exam  Exam?  @relation(fields: [examId], references: [id], onDelete: SetNull)
  tests Test[]

  // A given (exam, subject, grade) combo has ONE template. Templates with
  // examId=null form a shared library and can coexist with per-exam clones.
  @@unique([examId, subject, grade])
  @@index([examId])
}

// Global key/value settings — used for defaults like which report sections
// are unlocked on newly-created results. Small table (<20 rows expected)
// so JSON blobs are fine and no per-key column typing is needed.
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Actual runnable test authored by admin. Bound to a TestTemplate (the
// "yorliq") — question count must match template.questions.length so every
// slot of the pedagogical structure gets real content. Questions carry the
// real prompt, choices, and correct answers; server grades them at submit
// time.
model Test {
  id          String         @id @default(uuid())
  examId      String
  templateId  String
  name        String
  subject     SubjectKey
  grade       Int
  languages   TestLanguage[] @default([])
  durationSec Int?
  questions   Json // TestQuestion[] (see packages/compute/src/types.ts)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  exam     Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  template TestTemplate  @relation(fields: [templateId], references: [id], onDelete: Restrict)
  attempts TestAttempt[]

  @@index([grade, subject])
  @@index([examId])
  @@index([templateId])
}

// Every student who lands on the new test-taking site and submits the
// intro form becomes a Lead. If they start a test we mint a Student and
// link it; on completion the linked Result is bound via TestAttempt.
model Lead {
  id           String       @id @default(uuid())
  firstName    String
  lastName     String
  sex          StudentSex
  phone        String
  grade        Int
  examLanguage TestLanguage
  status       LeadStatus   @default(FORM_ONLY)
  studentId    String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  student  Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  attempts TestAttempt[]

  @@index([status, createdAt])
  @@index([phone])
}

// One row per Lead-starts-Test event. Holds mid-test answer state so a
// refresh can restore progress, and — on submit — links to the produced
// Result (which stays in DRAFT until admin publishes).
model TestAttempt {
  id            String    @id @default(uuid())
  leadId        String
  testId        String
  clientToken   String    @unique
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  autoSubmitted Boolean   @default(false)
  answers       Json      @default("{}")
  scoreRaw      Int?
  scoreMax      Int?
  // O'quvchi test davomida to'liq ekrandan necha marta chiqqani. Faqat
  // KUZATUV uchun — baholashga ta'sir qilmaydi va o'zi hech narsani
  // to'xtatmaydi. Brauzer Esc/F11 ni bloklashga ruxsat bermaydi, shuning
  // uchun "chiqmasin" emas, "chiqqani ko'rinsin" deb yozamiz.
  // Faqat o'sadi (server max(eski, yangi) qiladi): sahifa yangilansa
  // hisoblagich nolga tushib, oldingi chiqishlar yo'qolmasin.
  fullscreenExits Int     @default(0)
  // @unique EMAS: bir lead uchala fanni alohida topshiradi va uchala urinish
  // ham BITTA natijaga bog'lanadi (public.testtaking.ts submit uni yig'adi).
  // Ilgari 1:1 edi va ikkinchi fan topshirilganda unique cheklov qulardi.
  resultId      String?

  lead   Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  test   Test    @relation(fields: [testId], references: [id], onDelete: Restrict)
  result Result? @relation(fields: [resultId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([testId, submittedAt])
  @@index([resultId])
}

model AuditLog {
  id          String   @id @default(uuid())
  adminUserId String?
  action      String
  entityType  String
  entityId    String
  prev        Json?
  next        Json?
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}
