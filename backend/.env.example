# Database — Postgres in production. SQLite (file:./dev.db) works for local dev
# if you also change `provider` in prisma/schema.prisma to "sqlite".
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sodiq_exam?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET="replace-with-long-random-string"
RESULT_JWT_SECRET="replace-with-another-long-random-string"

# Cookie / CORS
COOKIE_SECURE=false
ADMIN_APP_URL=http://localhost:3000
CLIENT_APP_URL=http://localhost:4321
CORS_ORIGINS=http://localhost:3000,http://localhost:4321

# Seed defaults (only used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@sodiq.uz
SEED_ADMIN_PASSWORD=ChangeMe!2025
SEED_ADMIN_NAME="Test Admin"
